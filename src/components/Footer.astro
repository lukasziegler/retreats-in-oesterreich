---
import { author, footerMenu, site } from "../data/settings";
import Subscribe from "./Subscribe.astro";

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner">
    <Subscribe />

    <div class="container">
      <div class="row">
        <div class="col col-6 col-d-12">
          <div class="widget-footer widget-author">
            <div class="widget-author__avatar">
              <img
                src={author.avatar}
                alt={author.name}
                loading="lazy"
                decoding="async"
              />
            </div>
            <h3 class="widget-author__title">{author.name}</h3>
            <p class="widget-author__bio">{author.bio}</p>
          </div>
        </div>

        <div class="col col-2 col-m-12">
          <div class="widget-footer widget-nav">
            <h3 class="widget-footer__title">Menu</h3>
            <ul class="widget-nav__list list-reset">
              {
                footerMenu.map((item) => (
                  <li class="widget-nav__item">
                    <a href={item.url} class="widget-nav__link">
                      {item.title}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="footer__info">
    <div class="container">
      <div class="row">
        <div class="col col-12">
          <div class="copyright">
            {year} &copy; <a href="/impressum/">{site.title}</a>. Crafted &
            Designed by
            <a href="https://jekyllthemes.io/developers/artem-sheludko"
              >Artem Sheludko</a
            >.
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
