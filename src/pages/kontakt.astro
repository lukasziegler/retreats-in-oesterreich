---
import BaseLayout from "../layouts/BaseLayout.astro";
import { contact } from "../data/settings";

const title = "Kontakt";
const description =
  "Bist du genauso begeistert wie wir von der Magie und dem unglaublichen Potential von Retreats? Oder bist du einfach neugierig und selbst auf der Suche nach einer Auszeit um deine eigenen Weichen neu zu stellen?";
---

<BaseLayout title={title} description={description}>
  <div class="container">
    <div class="page-head">
      <div class="page__info">
        <h1 class="page__title">{title}</h1>
        <p class="page__description">{description}</p>
      </div>
    </div>
  </div>

  <div class="container animate">
    <article class="page">
      <div class="page__content">
        <p>
          Dann bist du hier genau richtig. Melde dich gerne über das
          Kontaktformular und du hörst binnen ein paar Tagen zurück von uns. Da
          dieses Projekt aktuell in der Freizeit stattfindet, habe bitte
          Verständnis dafür, dass die Antwort ggf. etwas dauert.
        </p>

        <div class="form-box">
          <form class="form" action={contact.formspree} method="POST">
            <div class="form__group">
              <label class="form__label screen-reader-text" for="form-name"
                >Dein Name</label
              >
              <input
                class="form__input"
                id="form-name"
                type="text"
                name="name"
                placeholder="Name"
                required
              />
            </div>
            <div class="form__group">
              <label class="form__label screen-reader-text" for="form-email"
                >Deine Email</label
              >
              <input
                class="form__input"
                id="form-email"
                type="email"
                name="_replyto"
                placeholder="E-Mail"
                required
              />
            </div>
            <div class="form__group">
              <label class="form__label screen-reader-text" for="form-text"
                >Deine Nachricht</label
              >
              <textarea
                class="form__input"
                id="form-text"
                name="text"
                rows="7"
                placeholder="Deine Nachricht"
                required></textarea>
            </div>
            <div class="form__group">
              <button class="button button--primary" type="submit"
                >Nachricht senden</button
              >
            </div>
          </form>
        </div>

        <hr />

        <img
          src="/images/stockphotos/austria/breathe+namaste nik-bUqtlRXVcS0-unsplash.jpg"
          alt="Breathe + Namaste"
          loading="lazy"
          decoding="async"
        />
        <em
          >Foto von <a href="https://unsplash.com/de/fotos/bUqtlRXVcS0">Nik</a
          ></em
        >
      </div>
    </article>
  </div>
</BaseLayout>
